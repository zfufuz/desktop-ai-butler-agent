# Renderer mode. The real Provider is selected in the application settings.
VITE_AI_PROVIDER=zhipu

# Development-only fallback. Never commit a real key.
ZHIPU_API_KEY=replace_with_your_key
ZHIPU_MODEL=glm-4-flash

# AMap Web Service key for weather, geocoding and route tools.
AMAP_API_KEY=replace_with_your_key
